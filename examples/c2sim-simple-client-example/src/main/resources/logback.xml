<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %highlight(%msg) - %logger{0} [%thread]%n</pattern>
        </encoder>
    </appender>
     <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
      </root>
</configuration>
