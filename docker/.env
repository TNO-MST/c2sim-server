C2SIM_SERVER_PORT=9999
GRAFANA_PORT=3000
KEYCLOACK_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=welcome
KEYCLOAK_ADMIN_PASSWORD=admin

# https://tno-mst.github.io/c2sim-server/c2sim-server/configuration/
# C2SIM_EXTERNAL_HOSTNAME will be returned as part of the websocket connect url, replace with server ip 
C2SIM_EXTERNAL_HOSTNAME="127.0.0.1"
C2SIM_BEARER_PUBLIC_KEY=""
C2SIM_IDENTITY_PROVIDER_URL="http://localhost:8080/realms/c2sim/.well-known/openid-configuration"
C2SIM_AUTH_MODE="MIXED_AUTH"